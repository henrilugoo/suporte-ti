      "type": "object",
      "properties": {
        "_id": {"type": "string"},
        "nome": {"type": "string"},
        "email": {"type": "string"},
        "cargo": {"type": "string"},
        "departamento": {"type": "string"}
      }
    },
    "Task": {
      "type": "object",
      "properties": {
        "_id": {"type": "string"},
        "titulo": {"type": "string"},
        "descricao": {"type": "string"},
        "prioridade": {"type": "string"},
        "status": {"type": "string"},
        "usuarioId": {"type": "string"}
      }
    },
    "Equipamento": {
      "type": "object",
      "properties": {
        "_id": {"type": "string"},
        "nome": {"type": "string"},
        "tipo": {"type": "string"},
        "marca": {"type": "string"},
        "modelo": {"type": "string"},
        "numeroSerie": {"type": "string"},
        "status": {"type": "string"},
        "localizacao": {"type": "string"}
      }
    },
    "Emprestimo": {
      "type": "object",
      "properties": {
        "_id": {"type": "string"},
        "equipamentoId": {"type": "string"},
        "usuarioId": {"type": "string"},
        "dataDevolucaoPrevista": {"type": "string"},
        "dataDevolucaoReal": {"type": "string"},
        "status": {"type": "string"}
      }
    },
    "Chamado": {
      "type": "object",
      "properties": {
        "_id": {"type": "string"},
        "titulo": {"type": "string"},
        "descricao": {"type": "string"},
        "prioridade": {"type": "string"},
        "status": {"type": "string"},
        "equipamentoId": {"type": "string"},
        "usuarioId": {"type": "string"}
      }
    }
  }
