{
  "swagger": "2.0",
  "info": {
    "title": "API de Suporte Técnico de TI",
    "description": "API completa para gerenciar suporte técnico",
    "version": "1.0.0"
  },
  "host": "localhost:8080",
  "basePath": "/",
  "schemes": ["http", "https"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "paths": {
    "/users": {
      "get": {
        "summary": "Lista todos os usuários",
        "responses": {
          "200": {
            "description": "Lista de usuários",
            "schema": {
              "type": "array",
              "items": {"$ref": "#/definitions/User"}
            }
          }
        }
      },
      "post": {
        "summary": "Cria um novo usuário",
        "parameters": [{
          "name": "body",
          "in": "body",
          "required": true,
          "schema": {
            "type": "object",
            "properties": {
              "nome": {"type": "string"},
              "email": {"type": "string"},
              "senha": {"type": "string"},
              "cargo": {"type": "string"},
              "departamento": {"type": "string"}
            }
          }
        }],
        "responses": {"201": {"description": "Usuário criado com sucesso"}}
      }
    },
    "/users/{id}": {
      "put": {
        "summary": "Atualiza um usuário",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "type": "string"},
          {"name": "body", "in": "body", "schema": {"type": "object"}}
        ],
        "responses": {"200": {"description": "Usuário atualizado"}}
      },
      "delete": {
        "summary": "Deleta um usuário",
        "parameters": [{"name": "id", "in": "path", "required": true, "type": "string"}],
        "responses": {"200": {"description": "Usuário deletado"}}
      }
    },
    "/tasks": {
      "get": {
        "summary": "Lista todas as tarefas",
        "responses": {
          "200": {
            "description": "Lista de tarefas",
            "schema": {
              "type": "array",
              "items": {"$ref": "#/definitions/Task"}
            }
          }
        }
      },
      "post": {
        "summary": "Cria uma nova tarefa",
        "parameters": [{"name": "body", "in": "body", "required": true, "schema": {"type": "object"}}],
        "responses": {"201": {"description": "Tarefa criada com sucesso"}}
      }
    },
    "/tasks/{id}": {
      "put": {
        "summary": "Atualiza uma tarefa",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "type": "string"},
          {"name": "body", "in": "body", "schema": {"type": "object"}}
        ],
        "responses": {"200": {"description": "Tarefa atualizada"}}
      },
      "delete": {
        "summary": "Deleta uma tarefa",
        "parameters": [{"name": "id", "in": "path", "required": true, "type": "string"}],
        "responses": {"200": {"description": "Tarefa deletada"}}
      }
    },
