          "200": {
            "description": "Lista de chamados",
            "schema": {
              "type": "array",
              "items": {"$ref": "#/definitions/Chamado"}
            }
          }
        }
      },
      "post": {
        "summary": "Cria um novo chamado",
        "parameters": [{"name": "body", "in": "body", "required": true, "schema": {"type": "object"}}],
        "responses": {"201": {"description": "Chamado criado com sucesso"}}
      }
    },
    "/chamados/{id}": {
      "put": {
        "summary": "Atualiza um chamado",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "type": "string"},
          {"name": "body", "in": "body", "schema": {"type": "object"}}
        ],
        "responses": {"200": {"description": "Chamado atualizado"}}
      },
      "delete": {
        "summary": "Deleta um chamado",
        "parameters": [{"name": "id", "in": "path", "required": true, "type": "string"}],
        "responses": {"200": {"description": "Chamado deletado"}}
      }
    }
  },
  "definitions": {
