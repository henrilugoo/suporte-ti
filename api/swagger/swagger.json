          "200": {
            "description": "Lista de equipamentos",
            "schema": {
              "type": "array",
              "items": {"$ref": "#/definitions/Equipamento"}
            }
          }
        }
      },
      "post": {
        "summary": "Cria um novo equipamento",
        "parameters": [{"name": "body", "in": "body", "required": true, "schema": {"type": "object"}}],
        "responses": {"201": {"description": "Equipamento criado com sucesso"}}
      }
    },
    "/equipamentos/{id}": {
      "put": {
        "summary": "Atualiza um equipamento",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "type": "string"},
          {"name": "body", "in": "body", "schema": {"type": "object"}}
        ],
        "responses": {"200": {"description": "Equipamento atualizado"}}
