          }
        }
      },
      "post": {
        "summary": "Cria um novo empréstimo",
        "parameters": [{"name": "body", "in": "body", "required": true, "schema": {"type": "object"}}],
        "responses": {"201": {"description": "Empréstimo criado com sucesso"}}
      }
    },
    "/emprestimos/{id}/devolver": {
      "put": {
        "summary": "Marca empréstimo como devolvido",
        "parameters": [{"name": "id", "in": "path", "required": true, "type": "string"}],
        "responses": {"200": {"description": "Empréstimo devolvido com sucesso"}}
      }
    },
    "/chamados": {
      "get": {
        "summary": "Lista todos os chamados",
